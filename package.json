{
  "name": "role-play-card",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "vue-renderer"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w vue-renderer",
    "dev:api": "python python-service/src/server.py --host 127.0.0.1 --port 8765 --app-data .role-play-card-data",
    "build": "npm run build -w vue-renderer",
    "typecheck": "npm run typecheck -w vue-renderer",
    "test:python": "python -m pytest python-service/tests",
    "test": "npm run test:python"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
